<robot xmlns:xacro="http://ros.org/wiki/xacro">
<xacro:macro name="base">

  <!-- chassis -->
  <link name="chassis">
    <inertial>
      <mass value="40.0"/>
      <inertia ixx="1.73333" iyy="4.56667" izz="4.56667"/>
    </inertial>
    <visual name="chassis_visual">
      <geometry>
        <mesh filename="package://simulator/models/ai_car1/meshes/AIF_body.dae"/>
      </geometry>
    </visual>
    <collision name="chassis_collision">
      <geometry>
        <mesh filename="package://simulator/models/ai_car1/meshes/AIF_body.dae"/>
      </geometry>
    </collision>
  </link>

  <!-- motor -->
  <link name="motor"/>
  <joint name="motor_joint" type="fixed">
    <parent link="chassis"/>
    <child link="motor"/>
    <origin xyz="0.7 0 0.33" rpy="0 0 0"/>
  </joint>

  <!-- motor_spin -->
  <link name="motor_spin"/>
  <joint name="motor_spin_joint" type="revolute">
    <parent link="motor"/>
    <child link="motor_spin"/>
    <origin xyz="0 0 0.022" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</xacro:macro>
</robot>

