<?xml version="1.0" ?>
<sdf version="1.5">
  <model name="ai_car1">
  <pose>0 0 0 0 0 0</pose>
    
    
    <link name="chassis">
      <pose relative_to='__model__'>0 0 0.15 0 0 3.14</pose>
    </link>


    <link name='motor'>
      <pose relative_to="chassis">0.7 0 0.33 0 0 0</pose>
      <inertial>
        <mass>7.0</mass>
        <inertia>
          <ixx>0.04778</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.04778</iyy>
          <iyz>0</iyz>
          <izz>0.07875</izz>
        </inertia>
      </inertial>

      <visual name='visual'>
        <geometry>
        <!--let's add color to our link-->
        <pose>0 0 0 0 0 0</pose>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/motor.dae</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name='collision'>
        <geometry>
        <pose>0 0 0 0 0 0</pose>
          <mesh>
	    <uri>package://simulator/models/ai_car1/meshes/motor.dae</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
      </collision>
    </link>

    <link name='motor_spin'>
      <pose relative_to="motor">0 0 0.022 0 0 0</pose>
      <inertial>
        <mass>7.0</mass>
        <inertia>
          <ixx>0.04778</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.04778</iyy>
          <iyz>0</iyz>
          <izz>0.07875</izz>
        </inertia>
      </inertial>

      <visual name='visual'>
        <geometry>
        <!--let's add color to our link-->
        <pose>0 0 0 0 0 0</pose>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/motor_spin.dae</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
	<material>
          <ambient>1.0 1.0 0.0 1</ambient>   <!-- 環境光：黄色 -->
          <diffuse>1.0 1.0 0.0 1</diffuse>   <!-- 拡散反射：黄色 -->
          <specular>0.2 0.2 0.2 1</specular> <!-- 少し光沢 -->
          <emissive>0 0 0 1</emissive>       <!-- 発光なし -->
        </material>
      </visual>
      <collision name='collision'>
        <geometry>
        <pose>0 0 0 0 0 0</pose>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/motor_spin.dae</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
      </collision>
    </link>

    <joint name='motor_joint' type='fixed'>
      <parent>chassis</parent>
      <child>motor</child>
    </joint>

    <joint name='motor_spin_joint' type='revolute'>
      <parent>motor</parent>
      <child>motor_spin</child>
      <axis>
        <xyz expressed_in='__model__'>0 0 1</xyz>
        <limit>
	  <lower>-6.283</lower>
	  <upper>6.283</upper>
	  <effort>9.4</effort>
        </limit>
        <dynamics>
          <friction>0.9</friction>  <!-- 静止摩擦 -->
        </dynamics>
      </axis>
    </joint>

    <!-- ========== ROS 2 Control設定 ========== -->
    <ros2_control name="MotorControlSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <joint name="motor_spin_joint">
        <command_interface name="position"/>
        <command_interface name="effort"/>
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="effort"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <ros>
        <namespace>/</namespace>
        <argument>robot_description:=ignore</argument>
      </ros>
      <parameters>/home/ikenta/ros2_ws/src/aiformula/simulator/config/8108_effort_controller.yaml</parameters>
    </plugin>
  </model>
</sdf>