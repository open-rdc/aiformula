<?xml version="1.0"?>
<robot name="ai_car1">


  <link name="base_link"/>

  <!-- ========== Chassis ========== -->
  <link name="chassis">
    <inertial>
      <mass value="30.0"/>
      <inertia ixx="1.73333" ixy="0" ixz="0"
               iyy="4.56667" iyz="0" izz="4.56667"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 3.14159"/>
      <geometry>
        <mesh filename="package://simulator/models/ai_car1/meshes/AIF_body.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 3.14159"/>
      <geometry>
        <mesh filename="package://simulator/models/ai_car1/meshes/AIF_body.dae"/>
      </geometry>
    </collision>
  </link>

  <!-- ========== Left Wheel ========== -->
  <link name="left_wheel">
    <inertial>
      <mass value="7.0"/>
      <inertia ixx="0.04778" ixy="0" ixz="0"
               iyy="0.04778" iyz="0" izz="0.07875"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.57"/>
      <geometry>
        <mesh filename="package://simulator/models/ai_car1/meshes/tire.dae" scale="0.05 0.12 0.12"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.57"/>
      <geometry>
        <mesh filename="package://simulator/models/ai_car1/meshes/tire.dae" scale="0.05 0.12 0.12"/>
      </geometry>
    </collision>
  </link>

  <!-- ========== Right Wheel ========== -->
  <link name="right_wheel">
    <inertial>
      <mass value="7.0"/>
      <inertia ixx="0.04778" ixy="0" ixz="0"
               iyy="0.04778" iyz="0" izz="0.07875"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.57"/>
      <geometry>
      <mesh filename="package://simulator/models/ai_car1/meshes/tire.dae" scale="0.05 0.12 0.12"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.57"/>
      <geometry>
      <mesh filename="package://simulator/models/ai_car1/meshes/tire.dae" scale="0.05 0.12 0.12"/>
      </geometry>
    </collision>
  </link>

  <!-- ========== Caster Yaw Link ========== -->
  <link name="caster_yaw"/>

  <!-- ========== Caster Wheel (Simple Sphere) ========== -->
  <link name="caster">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.0016" ixy="0" ixz="0"
               iyy="0.0016" iyz="0" izz="0.0016"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.062"/>
      </geometry>
      <material name="gray">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.062"/>
      </geometry>
    </collision>
  </link>

  <!-- ========== Joints ========== -->
  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <joint name="left_wheel_joint" type="revolute">
    <parent link="chassis"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1e9" upper="1e9" effort="84.0" velocity="100.0"/>
  </joint>

  <joint name="right_wheel_joint" type="revolute">
    <parent link="chassis"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1e9" upper="1e9" effort="84.0" velocity="100.0"/>
  </joint>

  <joint name="caster_yaw_wheel" type="revolute">
    <parent link="chassis"/>
    <child link="caster_yaw"/>
    <origin xyz="-0.8 0 0" rpy="0 0 1.57"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.26" upper="0.26" effort="1000000.0" velocity="10.0"/>
    <dynamics damping="10.0" friction="0.0"/>
  </joint>

  <joint name="caster_pitch_joint" type="revolute">
    <parent link="caster_yaw"/>
    <child link="caster"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1e9" upper="1e9" effort="1.0" velocity="10.0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- ========== IMU ========== -->
  <link name="imu_link"/>

  <joint name="imu_joint" type="fixed">
    <parent link="chassis"/>
    <child link="imu_link"/>
    <origin xyz="-0.032 0 0.068" rpy="0 0 0"/>
  </joint>

  <!-- ========== Camera ========== -->
  <link name="camera_link"/>

  <joint name="camera_joint" type="fixed">
    <parent link="chassis"/>
    <child link="camera_link"/>
    <origin xyz="0.055 0 0.54" rpy="0 0 0"/>
  </joint>

  <link name="camera_rgb_link"/>

  <joint name="camera_rgb_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_rgb_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_depth_link"/>

  <joint name="camera_depth_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========== Camera Optical Frame ========== -->
  <link name="camera_optical_link"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="-1.5707963267948966 0 -1.5707963267948966"/>
  </joint>

  <!-- ========== GPS ========== -->
  <link name="gps_link"/>

  <joint name="gps_joint" type="fixed">
    <parent link="chassis"/>
    <child link="gps_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <ros2_control name="gz_ros2_control" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="caster_yaw_wheel">
      <command_interface name="position">
        <param name="min">-0.26</param>
        <param name="max">0.26</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
