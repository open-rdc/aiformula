<?xml version="1.0" ?>
<sdf version="1.5">
  <model name="ai_car1">
  <pose>0 0 0 0 0 0</pose>
    
    
    <link name="chassis">
      <pose relative_to='__model__'>0 0 0.15 0 0 3.14</pose>
    </link>

    <link name='caster_yaw'>
      <self_collide>true</self_collide>
      <pose relative_to='chassis'>0 0.1 0.25 0 0 -1.57</pose>
      <inertial>
        <mass>5.0</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.001</iyy>
          <iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>

      <visual name='visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/castor_yaw.dae</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>   <!-- 環境光：黄色 -->
          <diffuse>1.0 0.0 0.0 1</diffuse>   <!-- 拡散反射：黄色 -->
          <specular>0.2 0.2 0.2 1</specular> <!-- 少し光沢 -->
          <emissive>0 0 0 1</emissive>       <!-- 発光なし -->
        </material>
      </visual>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/castor_yaw.dae</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
      </collision>
    </link>

    <link name='motor_spin_right'>
      <pose relative_to="caster_yaw">-0.04 0.0045 0.097 0 0 -0.175</pose>
      <inertial>
        <mass>0.00001</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>

      <visual name='visual'>
        <geometry>
        <!--let's add color to our link-->
        <pose>0 0 0 0 0 0</pose>
          <box>
            <size>0.017 0.005 0.01</size>
          </box>
        </geometry>
        <material>
          <ambient>1.0 1.0 0.0 1</ambient>   <!-- 環境光：黄色 -->
          <diffuse>1.0 1.0 0.0 1</diffuse>   <!-- 拡散反射：黄色 -->
          <specular>0.2 0.2 0.2 1</specular> <!-- 少し光沢 -->
          <emissive>0 0 0 1</emissive>       <!-- 発光なし -->
        </material>
      </visual>
      <collision name='collision'>
        <geometry>
        <pose>0 0 0 0 0 0</pose>
	  <box>
            <size>0.017 0.01 0.01</size>
          </box>
        </geometry>
      </collision>
    </link>

    <link name='motor_spin_left'>
      <pose relative_to="caster_yaw">-0.04 -0.0045 0.097 0 0 0.175</pose>
      <inertial>
        <mass>0.00001</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>

      <visual name='visual'>
        <geometry>
        <!--let's add color to our link-->
        <pose>0 0 0 0 0 0</pose>
          <box>
            <size>0.017 0.005 0.01</size>
          </box>
        </geometry>
        <material>
          <ambient>0.0 1.0 0.0 1</ambient>   <!-- 環境光：黄色 -->
          <diffuse>0.0 1.0 0.0 1</diffuse>   <!-- 拡散反射：黄色 -->
          <specular>0.2 0.2 0.2 1</specular> <!-- 少し光沢 -->
          <emissive>0 0 0 1</emissive>       <!-- 発光なし -->
        </material>
      </visual>
      <collision name='collision'>
        <geometry>
        <pose>0 0 0 0 0 0</pose>
	  <box>
            <size>0.017 0.01 0.01</size>
          </box>
        </geometry>
      </collision>
    </link>

    <link name='motor_spin_center'>
      <pose relative_to="caster_yaw">-0.0 0.0 0.05 0 0 -0.261</pose>
      <inertial>
        <mass>0.00001</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00001</iyy>
          <iyz>0</iyz>
          <izz>0.00001</izz>
        </inertia>
      </inertial>

      <visual name='visual'>
        <geometry>
        <!--let's add color to our link-->
        <pose>0 0 0 0 0 0</pose>
	  <cylinder>
            <radius>0.01</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>1.0 1.0 0.0 1</ambient>   <!-- 環境光：黄色 -->
          <diffuse>1.0 1.0 0.0 1</diffuse>   <!-- 拡散反射：黄色 -->
          <specular>0.2 0.2 0.2 1</specular> <!-- 少し光沢 -->
          <emissive>0 0 0 1</emissive>       <!-- 発光なし -->
        </material>
      </visual>
      <collision name='collision'>
        <geometry>
        <pose>0 0 0 0 0 0</pose>
	  <cylinder>
            <radius>0.01</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
      </collision>
    </link>

    <joint name='caster_yaw_wheel' type='revolute'>
      <parent>chassis</parent>
      <child>caster_yaw</child>
      <axis>
        <limit>
          <lower>-0.26</lower>
          <upper>0.26</upper>
        </limit>
        <dynamics>
          <damping>10.0</damping>
          <spring_stiffness>12.0</spring_stiffness>
          <spring_reference>0.0</spring_reference>
        </dynamics>
      </axis>
    </joint>

    <joint name='motor_spin_right_joint' type='fixed'>
      <parent>caster_yaw</parent>
      <child>motor_spin_right</child>
    </joint>
    <joint name='motor_spin_left_joint' type='fixed'>
      <parent>caster_yaw</parent>
      <child>motor_spin_left</child>
    </joint>
    <joint name='motor_spin_center_joint' type='fixed'>
      <parent>caster_yaw</parent>
      <child>motor_spin_center</child>
    </joint>

  </model>
</sdf>
