<?xml version="1.0" ?>
<sdf version="1.5">
  <model name="ai_car1">
  <pose>0 0 0 0 0 0</pose>

  <!-- ignition plugin -->

    <plugin
      filename="libignition-gazebo-diff-drive-system.so"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.6</wheel_separation>
      <wheel_radius>0.124</wheel_radius>
      <odom_publish_frequency>0.1</odom_publish_frequency>
      <topic>cmd_vel_twist</topic>
    </plugin>
    <plugin
      filename="gz_ros2_control-system"
      name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>/tmp/simulator_ai_car1_ros2_control.yaml</parameters>
      <controller_manager_name>controller_manager</controller_manager_name>
      <ros>
        <remapping>/caster_yaw_position_controller/commands:=/cmd_caster</remapping>
      </ros>
    </plugin>
    <plugin
        filename="libignition-gazebo-imu-system.so"
        name="ignition::gazebo::systems::Imu">
    </plugin>
    <plugin
        filename="libignition-gazebo-sensors-system.so"
        name="ignition::gazebo::systems::Sensors">
    </plugin>

    <ros2_control name="gz_ros2_control" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>
      <joint name="caster_yaw_wheel">
        <command_interface name="position">
          <param name="min">-0.26</param>
          <param name="max">0.26</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

    <!-- chassis -->

    <link name='chassis'>
      <pose relative_to='__model__'>0 0 0.15 0 0 3.14</pose>

      <inertial> <!--inertial properties of the link mass, inertia matix-->
        <inertia>
          <ixx>1.73333</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>4.56667</iyy>
          <iyz>0</iyz>
          <izz>4.56667</izz>
        </inertia>
        <mass>40.0</mass>
      </inertial>

      <visual name='visual'>
        <geometry>
        <!--let's add color to our link-->
        <pose>0 0 0 0 0 3.14</pose>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/AIF_body.dae</uri>
          </mesh>
        </geometry>
      </visual>

      <collision name='collision'>
        <pose>0 0 0 0 0 3.14</pose>
        <geometry>
        <pose>0 0 0 0 0 3.14</pose>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/AIF_body.dae</uri>
          </mesh>
        </geometry>
      </collision>
    </link>

    <!-- left wheel -->

    <link name='left_wheel'>
      <pose relative_to="chassis">0 -0.3 0 1.57 0 1.57</pose>
      <inertial>
        <mass>7.0</mass>
        <inertia>
          <ixx>0.04778</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.04778</iyy>
          <iyz>0</iyz>
          <izz>0.07875</izz>
        </inertia>
      </inertial>

      <visual name='visual'>
        <geometry>
        <!--let's add color to our link-->
        <pose>0 -0.3 0 1.57 0 1.57</pose>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/tire.dae</uri>
            <scale>0.05 0.12 0.12</scale>
          </mesh>
        </geometry>
      </visual>
      <collision name='collision'>
        <geometry>
        <pose>0 -0.3 0 1.57 0 1.57</pose>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/tire.dae</uri>
            <scale>0.05 0.12 0.12</scale>
          </mesh>
        </geometry>
      </collision>
    </link>

    <!-- right wheel -->

    <link name='right_wheel'>
      <pose relative_to="chassis">0 0.3 0 1.57 0 1.57</pose> <!--angles are in radian-->
      <inertial>
        <mass>7.0</mass>
        <inertia>
          <ixx>0.04778</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.04778</iyy>
          <iyz>0</iyz>
          <izz>0.07875</izz>
        </inertia>
      </inertial>

      <visual name='visual'>
        <geometry>
        <!--let's add color to our link-->
        <pose>0 0.3 0 1.57 0 1.57</pose>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/tire.dae</uri>
            <scale>0.05 0.12 0.12</scale>
          </mesh>
        </geometry>
      </visual>

      <collision name='collision'>
        <geometry>
        <pose>0 0.3 0 1.57 0 1.57</pose>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/tire.dae</uri>
            <scale>0.05 0.12 0.12</scale>
          </mesh>
        </geometry>
      </collision>
    </link>

    <!-- caster wheel -->

    <frame name="caster_frame" attached_to='chassis'>
        <pose>0.8 0 0 0 0 1.57</pose>
    </frame>

    <link name='caster_yaw'>
      <pose relative_to='caster_frame'/>
      <inertial>
        <mass>5.0</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.001</iyy>
          <iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
    </link>

    <link name='caster'>
      <pose relative_to='caster_yaw'/>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.04778</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.04778</iyy>
          <iyz>0</iyz>
          <izz>0.07875</izz>
        </inertia>
      </inertial>

      <visual name='visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/tire.dae</uri>
            <scale>0.1 0.1 0.1</scale>
          </mesh>
        </geometry>
      </visual>

      <collision name='collision'>
        <geometry>
          <mesh>
            <uri>package://simulator/models/ai_car1/meshes/tire.dae</uri>
            <scale>0.1 0.1 0.1</scale>
          </mesh>
        </geometry>
      </collision>
    </link>

    <!-- joint config -->

    <joint name='left_wheel_joint' type='revolute'>
      <pose relative_to='left_wheel'/>
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis>
        <xyz expressed_in='__model__'>0 1 0</xyz>
        <limit>
          <effort>84.4</effort>
        </limit>
        <dynamics>
          <friction>0.9</friction>  <!-- 静止摩擦 -->
        </dynamics>
      </axis>
    </joint>

    <joint name='right_wheel_joint' type='revolute'>
      <pose relative_to='right_wheel'/>
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis>
        <xyz expressed_in='__model__'>0 1 0</xyz>
        <limit>
          <effort>84.4</effort>
        </limit>
        <dynamics>
          <friction>0.9</friction>  <!-- 静止摩擦 -->
        </dynamics>
      </axis>
    </joint>

    <joint name='caster_yaw_wheel' type='revolute'>
      <parent>chassis</parent>
      <child>caster_yaw</child>
      <axis>
        <xyz expressed_in='__model__'>0 0 1</xyz>
        <limit>
          <lower>-0.26</lower>
          <upper>0.26</upper>
          <effort>1000000.0</effort>
        </limit>
        <dynamics>
          <damping>10.0</damping>
          <spring_stiffness>12.0</spring_stiffness>
          <spring_reference>0.0</spring_reference>
        </dynamics>
      </axis>
    </joint>

    <joint name='caster_pitch_joint' type='revolute'>
      <parent>caster_yaw</parent>
      <child>caster</child>
      <axis>
        <xyz expressed_in='__model__'>0 1 0</xyz>
        <dynamics>
          <damping>0.01</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- imu sensor -->

    <joint name="imu_joint" type="fixed">
      <parent>chassis</parent>
      <child>imu_link</child>
      <pose>-0.032 0 0.068 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <link name="imu_link">
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>20.0</update_rate> <!--Hz-->
        <visualize>true</visualize>
        <topic>imu_raw</topic>
      </sensor>
    </link>

    <!-- camera image -->

    <joint name="camera_joint" type="fixed">
      <parent>chassis</parent>
      <child>camera_link</child>
      <pose>0.35 0 0.55 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <link name="camera_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <iyy>1e-6</iyy>
          <izz>1e-6</izz>
        </inertia>
      </inertial>

      <visual name="camera_visual">
        <geometry>
          <box>
            <size>0.05 0.1 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.5 0.5 0.5 1</ambient>
        </material>
      </visual>

      <sensor name="realsense_d435" type="rgbd_camera">
        <update_rate>60.0</update_rate>
        <always_on>true</always_on>
        <topic>camera</topic>
        <ignition_frame_id>camera_link</ignition_frame_id>

        <camera name="camera">
          <horizontal_fov>1.91986</horizontal_fov>
          <vertical_fov>1.39626</vertical_fov>
          <image>
             <width>480</width>
             <height>300</height>
             <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.02</near>
            <far>20</far>
          </clip>
        </camera>
      </sensor>
    </link>

    <!-- GNSS sensor -->

    <joint name="gps_joint" type="fixed">
      <parent>chassis</parent>
      <child>gps_link</child>
      <pose>0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <link name="gps_link">
      <sensor name="gps_sensor" type="navsat">
        <always_on>true</always_on>
        <update_rate>1.0</update_rate>
        <topic>navsat</topic>
      </sensor>
    </link>

  </model>
</sdf>